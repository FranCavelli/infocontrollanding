---
import Logo from "./Logo.astro";
import {
  getT,
  localizePath,
  LOCALES,
  type Locale,
} from "~/i18n/translations";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const t = getT(locale);

const pathname = Astro.url.pathname;

const home = localizePath("/", locale);

const navItems = [
  { href: `${home}#servicios`, label: t.nav.servicios },
  { href: `${home}#ia`, label: t.nav.ia },
  { href: `${home}#funcionalidades`, label: t.nav.funcionalidades },
  { href: `${home}#clientes`, label: t.nav.clientes },
  { href: `${home}#contacto`, label: t.nav.contacto },
];

const localeFlags: Record<Locale, string> = {
  es: "ES",
  en: "EN",
  pt: "PT",
};
---

<header
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-header
  transition:persist="site-header"
>
  <div class="container-pad">
    <div
      class="mt-4 flex items-center justify-between rounded-full border px-4 py-2.5 backdrop-blur-xl md:px-6"
      style="border-color: var(--border-1); background: color-mix(in oklab, var(--color-bg-soft) 88%, transparent);"
    >
      <Logo />

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Principal">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="rounded-full px-4 py-2 text-sm transition-colors hover:text-[color:var(--color-text)]"
              style="color: var(--color-text-muted);"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <!-- Theme toggle -->
        <button
          type="button"
          class="relative inline-flex h-9 w-9 items-center justify-center rounded-full border transition-colors"
          style="border-color: var(--border-1); background: var(--overlay-1); color: var(--color-text-muted);"
          aria-label="Cambiar tema"
          data-theme-toggle
        >
          <svg
            class="h-4 w-4 theme-icon-light"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
          <svg
            class="h-4 w-4 theme-icon-dark"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>

        <!-- Language switcher -->
        <div
          class="hidden items-center gap-1 rounded-full border p-1 text-xs md:flex"
          style="border-color: var(--border-1); background: var(--overlay-1);"
          data-lang-switcher
        >
          {
            LOCALES.map((l) => (
              <a
                href={localizePath(pathname, l)}
                class="lang-link rounded-full px-2.5 py-1 font-medium transition-colors"
                data-lang={l}
                aria-current={l === locale ? "page" : undefined}
              >
                {localeFlags[l]}
              </a>
            ))
          }
        </div>

        <a href="https://www.infocontrolweb.com/" target="_blank" rel="noopener noreferrer" class="btn btn-primary !px-5 !py-2 text-xs">
          {t.nav.ingresar}
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <button
          type="button"
          class="ml-1 inline-flex h-9 w-9 items-center justify-center rounded-full border lg:hidden"
          style="border-color: var(--border-1); background: var(--overlay-1); color: var(--color-text);"
          aria-label="Abrir menú"
          data-mobile-toggle
        >
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    class="container-pad pointer-events-none lg:hidden"
    data-mobile-panel
    aria-hidden="true"
  >
    <div
      class="mt-2 origin-top scale-95 rounded-3xl border p-3 opacity-0 backdrop-blur-xl transition-all duration-300"
      style="border-color: var(--border-1); background: color-mix(in oklab, var(--color-bg-soft) 95%, transparent);"
      data-mobile-inner
    >
      <nav class="flex flex-col" aria-label="Móvil">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="rounded-2xl px-4 py-3 text-sm transition-colors hover:text-[color:var(--color-text)]"
              style="color: var(--color-text-muted);"
            >
              {item.label}
            </a>
          ))
        }
        <div
          class="mt-2 flex items-center gap-1.5 px-4 pt-3 text-xs"
          style="border-top: 1px solid var(--border-1);"
          data-lang-switcher
        >
          <span style="color: var(--color-text-dim);">Lang</span>
          {
            LOCALES.map((l) => (
              <a
                href={localizePath(pathname, l)}
                class="lang-link ml-auto rounded-full px-2.5 py-1"
                data-lang={l}
                aria-current={l === locale ? "page" : undefined}
              >
                {localeFlags[l]}
              </a>
            ))
          }
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  /* Mostrar el ícono opuesto al tema actual */
  :root[data-theme="dark"] .theme-icon-dark {
    display: none;
  }
  :root[data-theme="light"] .theme-icon-light {
    display: none;
  }
  [data-header].is-scrolled > div > div {
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.18);
  }

  /* Estado activo / inactivo del switcher de idioma */
  .lang-link {
    color: var(--color-text-muted);
    background: transparent;
  }
  .lang-link[aria-current="page"] {
    color: var(--color-text);
    background: var(--overlay-3);
  }
  .lang-link:hover {
    color: var(--color-text);
  }
</style>

<script>
  const init = () => {
    const header = document.querySelector<HTMLElement>("[data-header]");
    if (!header || (header as any).__inited) return;
    (header as any).__inited = true;

    const onScroll = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 8);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const toggle = header.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
    const panel = header.querySelector<HTMLElement>("[data-mobile-panel]");
    const inner = header.querySelector<HTMLElement>("[data-mobile-inner]");
    let open = false;

    const setOpen = (v: boolean) => {
      open = v;
      if (!panel || !inner) return;
      panel.setAttribute("aria-hidden", String(!open));
      panel.classList.toggle("pointer-events-none", !open);
      inner.classList.toggle("opacity-0", !open);
      inner.classList.toggle("scale-95", !open);
      inner.classList.toggle("opacity-100", open);
      inner.classList.toggle("scale-100", open);
    };

    toggle?.addEventListener("click", () => setOpen(!open));
    panel
      ?.querySelectorAll("a")
      .forEach((a) => a.addEventListener("click", () => setOpen(false)));

    document.addEventListener("astro:before-preparation", () => setOpen(false));
  };

  init();
  document.addEventListener("astro:page-load", init);

  // === Sincronizar el switcher de idioma con la URL actual ===
  // El header está transition:persist, así que sus links no se re-renderizan.
  // Recalculamos hrefs y aria-current en cada navegación.
  type Lang = "es" | "en" | "pt";

  const RAW_BASE = (import.meta.env.BASE_URL || "/") as string;
  const BASE = RAW_BASE.replace(/\/+$/, "");

  const stripBase = (p: string): string => {
    if (BASE && p.startsWith(BASE)) {
      const r = p.slice(BASE.length);
      return r.startsWith("/") ? r : "/" + r;
    }
    return p;
  };
  const getLocale = (pathname: string): Lang => {
    const p = stripBase(pathname);
    if (p.startsWith("/en")) return "en";
    if (p.startsWith("/pt")) return "pt";
    return "es";
  };
  const localize = (pathname: string, target: Lang): string => {
    let p = stripBase(pathname).replace(/\/+$/, "") || "/";
    if (p === "/en" || p === "/pt") p = "/";
    else if (p.startsWith("/en/") || p.startsWith("/pt/")) p = p.slice(3) || "/";
    const loc =
      target === "es" ? p : p === "/" ? `/${target}/` : `/${target}${p}`;
    return BASE + loc;
  };

  const syncSwitcher = () => {
    const currentLocale = getLocale(location.pathname);
    document
      .querySelectorAll<HTMLAnchorElement>("a.lang-link[data-lang]")
      .forEach((a) => {
        const lang = a.dataset.lang as Lang;
        a.href = localize(location.pathname, lang);
        if (lang === currentLocale) a.setAttribute("aria-current", "page");
        else a.removeAttribute("aria-current");
      });
  };

  syncSwitcher();
  document.addEventListener("astro:after-swap", syncSwitcher);
  document.addEventListener("astro:page-load", syncSwitcher);
</script>
