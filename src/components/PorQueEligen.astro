---
import { getT, type Locale } from "~/i18n/translations";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const t = getT(locale).porQue;
---

<section id="ia" class="relative py-24 md:py-32">
  <div class="container-pad">
    <div class="reveal mx-auto max-w-3xl text-center">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 class="mt-5 font-display text-3xl font-bold leading-tight md:text-5xl">
        {t.titleLead}
        <span class="text-gradient">{t.titleHighlight}</span>
      </h2>
      <p class="mx-auto mt-5 max-w-2xl" style="color: var(--color-text-muted);">
        {t.desc}
      </p>
    </div>

    <div class="relative mt-16">
      <div
        class="absolute inset-0 -z-10 rounded-[2.5rem] opacity-60 blur-3xl"
        style="background: radial-gradient(60% 50% at 50% 50%, rgba(124,92,255,0.18), transparent 70%);"
      ></div>

      <div class="grid gap-5 md:grid-cols-3">
        {
          t.items.map((it, i) => (
            <article
              class="reveal group relative overflow-hidden rounded-3xl glass p-8"
            >
              <div class="absolute right-6 top-6 font-display text-5xl font-bold opacity-30 transition-opacity duration-500 group-hover:opacity-50" style="color: var(--color-brand);">
                0{i + 1}
              </div>

              <div class="flex items-baseline gap-2">
                <span class="font-display text-4xl font-bold text-gradient md:text-5xl">
                  {it.metric}
                </span>
              </div>
              <p class="mt-1 text-xs uppercase tracking-wider" style="color: var(--color-text-dim);">
                {it.metricLabel}
              </p>

              <h3 class="mt-7 font-display text-xl font-bold" style="color: var(--color-text);">
                {it.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-text-muted);">
                {it.text}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
