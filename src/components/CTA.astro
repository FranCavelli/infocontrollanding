---
import { getT, type Locale } from "~/i18n/translations";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const t = getT(locale).cta;
---

<section id="contacto" class="relative py-24 md:py-32">
  <div class="container-pad">
    <div
      class="reveal relative overflow-hidden rounded-[2rem] border p-10 md:p-16"
      style="border-color: var(--border-1);"
    >
      <div
        class="absolute inset-0 -z-10"
        style="background: radial-gradient(80% 100% at 50% 0%, rgba(11,187,239,0.22), transparent 60%), radial-gradient(60% 80% at 100% 100%, rgba(124,92,255,0.18), transparent 60%), var(--color-bg-soft);"
      ></div>

      <div
        class="absolute inset-0 -z-10 opacity-50"
        style="background-image: radial-gradient(circle at 20% 30%, var(--overlay-2) 1px, transparent 1px), radial-gradient(circle at 80% 70%, var(--overlay-2) 1px, transparent 1px); background-size: 32px 32px, 48px 48px;"
      ></div>

      <div class="grid gap-10 md:grid-cols-[1.4fr_1fr] md:items-center">
        <div>
          <span class="eyebrow">{t.eyebrow}</span>
          <h2 class="mt-5 font-display text-3xl font-bold leading-tight md:text-5xl">
            {t.titleLead}
            <span class="text-gradient">{t.titleHighlight}</span> {t.titleEnd}
          </h2>
          <p class="mt-5 max-w-lg" style="color: var(--color-text-muted);">
            {t.desc}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="mailto:contacto@infocontrol.io" class="btn btn-primary">
              {t.ctaPrimary}
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="mailto:contacto@infocontrol.io" class="btn btn-ghost">
              {t.ctaSecondary}
            </a>
          </div>
        </div>

        <ul class="grid grid-cols-1 gap-3">
          {
            t.bullets.map((p) => (
              <li class="flex items-start gap-3 rounded-2xl glass p-4">
                <span
                  class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full"
                  style="background: color-mix(in oklab, var(--color-brand) 15%, transparent); color: var(--color-brand);"
                >
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M5 10l3.5 3.5L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="text-sm" style="color: var(--color-text);">{p}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
