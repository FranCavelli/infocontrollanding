---
import { getT, type Locale } from "~/i18n/translations";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const t = getT(locale).video;

const VIDEO_ID = "dQw4w9WgXcQ";
---

<section id="video" class="relative py-24 md:py-32">
  <div class="container-pad">
    <div class="reveal mx-auto max-w-3xl text-center">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 class="mt-5 font-display text-3xl font-bold leading-tight md:text-5xl">
        {t.title}
      </h2>
    </div>

    <div class="reveal relative mx-auto mt-12 aspect-video w-full max-w-5xl">
      <div
        class="absolute -inset-6 -z-10 rounded-[2.5rem] opacity-60 blur-3xl"
        style="background: radial-gradient(50% 50% at 50% 50%, rgba(11,187,239,0.35), transparent 70%);"
      ></div>

      <button
        type="button"
        class="group relative h-full w-full overflow-hidden rounded-3xl border"
        style="border-color: var(--border-1); background: var(--color-bg-soft);"
        data-video-trigger
        aria-label="Reproducir video"
      >
        <div
          class="absolute inset-0 transition-transform duration-700 group-hover:scale-105"
          style={`background: linear-gradient(135deg, var(--color-bg-soft), var(--color-bg)), url('https://i.ytimg.com/vi/${VIDEO_ID}/maxresdefault.jpg') center/cover; opacity: 0.85;`}
        >
        </div>

        <div
          class="absolute inset-0"
          style="background: linear-gradient(0deg, color-mix(in oklab, var(--color-bg) 70%, transparent), transparent);"
        ></div>

        <div class="relative flex h-full w-full items-center justify-center">
          <span class="absolute inline-flex h-20 w-20 animate-ping rounded-full bg-[color:var(--color-brand)]/30 md:h-24 md:w-24"></span>
          <span class="relative inline-flex h-20 w-20 items-center justify-center rounded-full bg-white text-[#001119] shadow-2xl transition-transform duration-300 group-hover:scale-110 md:h-24 md:w-24">
            <svg class="h-7 w-7 translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M6 4l11 6-11 6V4z" />
            </svg>
          </span>
        </div>
      </button>
    </div>
  </div>
</section>

<script define:vars={{ VIDEO_ID }}>
  const trigger = document.querySelector("[data-video-trigger]");
  trigger?.addEventListener("click", () => {
    const iframe = document.createElement("iframe");
    iframe.setAttribute("title", "Infocontrol — video");
    iframe.setAttribute(
      "allow",
      "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    );
    iframe.setAttribute("allowfullscreen", "");
    iframe.src = `https://www.youtube.com/embed/${VIDEO_ID}?autoplay=1&rel=0`;
    iframe.className = "absolute inset-0 h-full w-full rounded-3xl";
    trigger.replaceWith(iframe);
  });
</script>
