---
import { localizePath, type Locale } from "~/i18n/translations";

interface Props {
  class?: string;
  locale?: Locale;
}
const { class: className = "", locale = "es" } = Astro.props;
const home = localizePath("/", locale);
---

<a href={home} class={`flex items-center gap-2.5 group ${className}`} aria-label="Infocontrol — ir al inicio">
  <svg viewBox="0 0 64 64" class="h-8 w-8 transition-transform duration-500 group-hover:rotate-12" aria-hidden="true">
    <defs>
      <linearGradient id="logoGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#38d4ff" />
        <stop offset="100%" stop-color="#0a8ab8" />
      </linearGradient>
    </defs>
    <polygon points="6,38 28,37.9 36,12" fill="url(#logoGrad)" />
    <polygon points="58,32 36,32.1 28,58" fill="url(#logoGrad)" opacity="0.7" />
  </svg>
  <span
    class="font-display text-xl font-bold tracking-tight"
    style="color: var(--color-text);"
  >
    info<span style="color: var(--color-brand);">control</span>
  </span>
</a>
