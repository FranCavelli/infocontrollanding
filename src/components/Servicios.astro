---
import { getT, type Locale } from "~/i18n/translations";
import ServicesCarousel from "./ServicesCarousel.astro";

interface Props {
  locale?: Locale;
}
const { locale = "es" } = Astro.props;
const t = getT(locale).servicios;

const iconKeys = ["cloud", "shield", "code", "plug"] as const;
const hrefs = ["#plataforma", "#auditoria", "#dev", "#integraciones"];

const icons: Record<string, string> = {
  cloud: `<path d="M7 18a4 4 0 0 1-.4-7.97A6 6 0 0 1 18 9.5a4.5 4.5 0 0 1-.5 8.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  shield: `<path d="M12 3l8 3v6c0 4.5-3.4 8.6-8 9-4.6-.4-8-4.5-8-9V6l8-3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  code: `<path d="M9 6l-6 6 6 6M15 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  plug: `<path d="M9 2v4M15 2v4M7 7h10v5a5 5 0 0 1-10 0V7zM12 17v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
};
---

<section id="servicios" class="relative py-24 md:py-32">
  <div class="container-pad">
    <div class="reveal flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <span class="eyebrow">{t.eyebrow}</span>
        <h2 class="mt-4 font-display text-3xl font-bold leading-tight md:text-5xl">
          {t.titleLead}
          <span class="text-gradient">{t.titleHighlight}</span>
        </h2>
      </div>
      <p class="max-w-md" style="color: var(--color-text-muted);">{t.desc}</p>
    </div>

    <!-- Carrusel de mockups de la plataforma. Si no te gusta, eliminá esta línea. -->
    <ServicesCarousel />

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.items.map((s, i) => (
          <a
            href={hrefs[i]}
            class="reveal group relative flex flex-col gap-5 overflow-hidden rounded-3xl glass p-7 transition-all duration-500 hover:-translate-y-1"
          >
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100"
              style="background: radial-gradient(circle, rgba(11,187,239,0.45), transparent 70%);"
            />
            <div
              class="flex h-12 w-12 items-center justify-center rounded-2xl border"
              style="border-color: var(--border-1); background: var(--overlay-1); color: var(--color-brand);"
            >
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" set:html={icons[iconKeys[i]]} />
            </div>

            <div class="flex flex-col gap-2">
              <h3 class="font-display text-lg font-bold" style="color: var(--color-text);">
                {s.title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
                {s.text}
              </p>
            </div>

            <div class="mt-auto inline-flex items-center gap-2 text-sm font-medium" style="color: var(--color-brand);">
              <span>{t.learnMore}</span>
              <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
