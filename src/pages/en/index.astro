---
import Base from "~/layouts/Base.astro";
import Header from "~/components/Header.astro";
import Hero from "~/components/Hero.astro";
import Servicios from "~/components/Servicios.astro";
import Funcionalidades from "~/components/Funcionalidades.astro";
import PorQueEligen from "~/components/PorQueEligen.astro";
import VideoSection from "~/components/VideoSection.astro";
import Clientes from "~/components/Clientes.astro";
import CTA from "~/components/CTA.astro";
import Footer from "~/components/Footer.astro";
import { pageFade } from "~/lib/transitions";

const locale = "en" as const;
---

<Base
  locale={locale}
  title="Infocontrol — AI-powered Contractor Management"
  description="SaaS platform with AI to administer and audit documentation of contractors and outsourced staff. Reduce outsourcing risks across LATAM."
>
  <Header locale={locale} />
  <main transition:animate={pageFade}>
    <Hero locale={locale} />
    <Servicios locale={locale} />
    <Funcionalidades locale={locale} />
    <PorQueEligen locale={locale} />
    <VideoSection locale={locale} />
    <Clientes locale={locale} />
    <CTA locale={locale} />
  </main>
  <Footer locale={locale} />
</Base>
